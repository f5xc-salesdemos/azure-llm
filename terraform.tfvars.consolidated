location            = "centralus"
admin_username      = "azureuser"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Consolidated mode: single Qwen 3.6 serves all roles
llm01_deployed       = true
llm02_deployed       = false
llm03_deployed       = false
workstation_deployed = true

# llm01 — Qwen 3.6 35B-A3B serves all model roles (2x A100 80GB, 1M ctx)
llm01_vm_size              = "Standard_NC48ads_A100_v4"
llm01_zone                 = "2"
llm01_disk_size            = 256
llm01_model_id             = "Qwen/Qwen3.6-35B-A3B"
llm01_tp_size              = 2
llm01_tool_call_parser     = "qwen3_coder"
llm01_reasoning_parser     = "qwen3"
llm01_max_model_len        = 1010000
llm01_allow_long_context   = true
llm01_extra_served_names   = "small-llm,medium-llm,vision-llm"
llm01_hf_overrides         = "{\"text_config\":{\"rope_parameters\":{\"rope_type\":\"yarn\",\"rope_theta\":10000000,\"factor\":4.0,\"original_max_position_embeddings\":262144,\"partial_rotary_factor\":0.25,\"mrope_interleaved\":true,\"mrope_section\":[11,11,10]}}}"

# llm03 — PersonaPlex (disabled)
llm03_vm_size = "Standard_NC40ads_H100_v5"
llm03_zone    = ""

# Workstation — T4 for Chrome/Playwright
workstation_vm_size = "Standard_NC8as_T4_v3"
workstation_zone    = "2"
