{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma 4 31B",
      "options": {
        "baseURL": "http://10.0.0.10:8000/v1",
        "apiKey": "local-vllm"
      },
      "models": {
        "gemma-4-31b": {
          "name": "Gemma 4 31B",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    },
    "vllm-subagent": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Phi-4-mini",
      "options": {
        "baseURL": "http://10.0.0.11:8000/v1",
        "apiKey": "local-vllm"
      },
      "models": {
        "phi-4-mini": {
          "name": "Phi-4-mini (GitHub Ops)",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        }
      }
    },
    "vllm-devstral": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Devstral-24B (Coding Agent / Tool Calling)",
      "options": {
        "baseURL": "http://10.0.0.11:8002/v1",
        "apiKey": "local-vllm"
      },
      "models": {
        "devstral-24b": {
          "name": "Devstral-24B (Coding Agent / Tool Calling)",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "vllm/gemma-4-31b",
  "permission": "allow"
}
