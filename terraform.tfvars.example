# Copy this file to terraform.tfvars and customize
# Create secrets.auto.tfvars for sensitive values (gitignored)

# Infrastructure
resource_group_name = "my-llm-rg"
location            = "centralus"
vm_name             = "gpu-llm-vm"
vm_size             = "Standard_NC48ads_A100_v4"  # 2x A100 80GB ($7.34/hr)
zone                = "2"                          # "" = Azure picks
admin_username      = "azureuser"
ssh_public_key_path = "~/.ssh/id_rsa.pub"
os_disk_size_gb     = 512

# Model configuration
model_id              = "google/gemma-4-31B-it"    # HuggingFace model ID
served_model_name     = "gemma-4-31b"              # Name exposed in API
max_model_len         = 131072                      # 128K context
gpu_memory_utilization = 0.95                       # 0.90 = safe, 0.95 = max
tool_call_parser      = "gemma4"                    # gemma4, hermes, llama4_pythonic
vllm_port             = 8000

# OS image (default: Ubuntu 24.04 LTS)
# os_image = {
#   publisher = "Canonical"
#   offer     = "ubuntu-24_04-lts"
#   sku       = "server"
#   version   = "latest"
# }

# Create secrets.auto.tfvars (gitignored) with:
# subscription_id = "your-azure-subscription-id"
# hf_token        = "hf_your_huggingface_token"
